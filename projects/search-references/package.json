{
  "name": "es-search-references",
  "version": "0.1.0",
  "description": "JavaScript reference tracking by static analysis.  For libraries to test they don't leak memory directly.",
  "exports": {
    "./core-host": {
      "import": {
        "default": "./dist/core-host/runSearchesInGuestEngine.js",
        "types": "./dist/core-host/runSearchesInGuestEngine.d.ts"
      }
    },
    "./guest": {
      "import": {
        "default": "./dist/guest/searchReferences.js",
        "types": "./dist/guest/searchReferences.d.ts"
      }
    },
    "./host": {
      "import": {
        "default": "./dist/host/runSearchesInGuestEngine.js",
        "types": "./dist/host/runSearchesInGuestEngine.d.ts"
      }
    }
  },
  "files": [
    "./dist/core-host/*",
    "./dist/host/*",
    "./dist/guest/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=25.8.2"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && node ../../node_modules/gulp/bin/gulp.js",
    "debug": "npm run clean && node --inspect-brk ../../node_modules/gulp/bin/gulp.js",
    "tasks": "npm run clean && node ../../node_modules/gulp/bin/gulp.js --tasks",
    "is-repo-clean": "node ./gulp-utilities/assertRepoIsClean.js"
  },
  "author": "Alexander J. Vincent <ajvincent@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "@ajvincent/build-utilities": "file:../build-utilities",
    "@types/gulp": "^4.0.17",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^18.19.69",
    "gulp": "^5.0.0",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "type-fest": "^4.40.0"
  },
  "dependencies": {
    "@dagrejs/graphlib": "^2.2.4",
    "@engine262/engine262": "^0.0.1-cf7664314152f0b0abe93dd0e5fdcab6bb1ab829",
    "import-meta-resolve": "^4.1.0"
  }
}
